									"pm.test(\"Status code é 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response tem dados do veículo\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('placa');",
									"    pm.expect(jsonData).to.have.property('renavam');",
									"    pm.expect(jsonData).to.have.property('marca_modelo');",
									"});",
									"",
									"pm.test(\"Tempo de resposta aceitável\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(10000);",
									"});",
									"",
									"pm.test(\"Headers corretos\", function () {",
									"    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
									"});"
