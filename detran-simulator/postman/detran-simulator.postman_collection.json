		{
			"name": "🔄 Testes de Instabilidade",
			"item": [
				{
					"name": "⏱️ Teste de Timeout (Múltiplas Tentativas)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Este teste pode retornar 200, 408 ou 503 dependendo da simulação",
									"pm.test(\"Status code é válido (200, 408 ou 503)\", function () {",
									"    const validStatuses = [200, 408, 503];",
									"    pm.expect(validStatuses).to.include(pm.response.code);",
									"});",
									"",
									"if (pm.response.code === 408) {",
									"    pm.test(\"Timeout simulado detectado\", function () {",
									"        console.log('⏱️ Timeout simulado ocorreu');",
									"    });",
									"} else if (pm.response.code === 503) {",
									"    pm.test(\"Indisponibilidade simulada detectada\", function () {",
									"        console.log('🔴 Indisponibilidade simulada ocorreu');",
									"    });",
									"} else {",
									"    pm.test(\"Consulta bem-sucedida\", function () {",
									"        console.log('✅ Consulta realizada com sucesso');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
