# =====================================================
# Variáveis de Ambiente - Arquitetura Híbrida
# =====================================================
# Copie este arquivo para .env e ajuste os valores
# Comando: cp .env.example .env
# =====================================================

# =====================================================
# APLICAÇÃO
# =====================================================
SPRING_PROFILES_ACTIVE=docker
SERVER_PORT=8083

# =====================================================
# POSTGRESQL - WRITE DATABASE (Event Store)
# =====================================================
WRITE_DB_HOST=postgres-write
WRITE_DB_PORT=5432
WRITE_DB_NAME=sinistros_eventstore
WRITE_DB_USERNAME=postgres
WRITE_DB_PASSWORD=postgres_secure_password_here
WRITE_DB_URL=jdbc:postgresql://${WRITE_DB_HOST}:${WRITE_DB_PORT}/${WRITE_DB_NAME}

# Pool de Conexões - Write
WRITE_DB_POOL_SIZE=20
WRITE_DB_POOL_MIN_IDLE=5
WRITE_DB_CONNECTION_TIMEOUT=30000

# =====================================================
# POSTGRESQL - READ DATABASE (Projections)
# =====================================================
READ_DB_HOST=postgres-read
READ_DB_PORT=5432
READ_DB_NAME=sinistros_projections
READ_DB_USERNAME=postgres
READ_DB_PASSWORD=postgres_secure_password_here
READ_DB_URL=jdbc:postgresql://${READ_DB_HOST}:${READ_DB_PORT}/${READ_DB_NAME}

# Pool de Conexões - Read
READ_DB_POOL_SIZE=50
READ_DB_POOL_MIN_IDLE=10
READ_DB_CONNECTION_TIMEOUT=20000

# =====================================================
# REDIS (Cache)
# =====================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2000
REDIS_POOL_MAX_ACTIVE=20
REDIS_POOL_MAX_IDLE=10
REDIS_POOL_MIN_IDLE=5

# Cache TTL
CACHE_TTL_HOURS=24
CACHE_QUERY_TTL_MINUTES=5

# =====================================================
# KAFKA (Event Bus)
# =====================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_GROUP_ID=sinistros-hibrida
KAFKA_AUTO_OFFSET_RESET=earliest

# Tópicos Kafka
KAFKA_TOPIC_DOMAIN_EVENTS=domain-events-topic
KAFKA_TOPIC_INTEGRATION_EVENTS=integration-events-topic
KAFKA_TOPIC_NOTIFICATION_EVENTS=notification-events-topic

# Configurações de Performance Kafka
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_RETRIES=3
KAFKA_CONSUMER_MAX_POLL_RECORDS=500

# =====================================================
# SEGURANÇA
# =====================================================
# OAuth2 JWT (opcional - descomente se usar)
# JWT_ISSUER_URI=http://keycloak:8080/auth/realms/sinistros
# JWT_JWK_SET_URI=http://keycloak:8080/auth/realms/sinistros/protocol/openid-connect/certs

# Spring Security
SECURITY_ENABLED=true

# =====================================================
# EVENT STORE
# =====================================================
# Serialização
EVENTSTORE_SERIALIZATION_FORMAT=json
EVENTSTORE_COMPRESSION=gzip
EVENTSTORE_COMPRESSION_THRESHOLD=1024

# Performance
EVENTSTORE_BATCH_SIZE=100
EVENTSTORE_WRITE_TIMEOUT=30
EVENTSTORE_READ_TIMEOUT=15
EVENTSTORE_CACHE_ENABLED=true
EVENTSTORE_CACHE_TTL=300

# Particionamento
EVENTSTORE_PARTITIONING_ENABLED=true
EVENTSTORE_PARTITIONING_STRATEGY=monthly
EVENTSTORE_PARTITIONING_FUTURE_PARTITIONS=3

# Arquivamento
EVENTSTORE_ARCHIVE_ENABLED=true
EVENTSTORE_ARCHIVE_AFTER_YEARS=2
EVENTSTORE_ARCHIVE_DELETE_AFTER=false
EVENTSTORE_ARCHIVE_BASE_PATH=/app/data/archives

# Replay
EVENTSTORE_REPLAY_ENABLED=true
EVENTSTORE_REPLAY_BATCH_SIZE=100
EVENTSTORE_REPLAY_MAX_CONCURRENT=5

# =====================================================
# SNAPSHOTS
# =====================================================
SNAPSHOT_THRESHOLD=50
SNAPSHOT_MAX_PER_AGGREGATE=5
SNAPSHOT_COMPRESSION_ENABLED=true
SNAPSHOT_COMPRESSION_ALGORITHM=GZIP
SNAPSHOT_AUTO_CLEANUP_ENABLED=true
SNAPSHOT_CLEANUP_INTERVAL_HOURS=24
SNAPSHOT_ASYNC_CREATION=true
SNAPSHOT_RETENTION_DAYS=365

# =====================================================
# CQRS
# =====================================================
CQRS_COMMAND_TIMEOUT=30s
CQRS_COMMAND_RETRY_MAX_ATTEMPTS=3
CQRS_QUERY_CACHE_TTL=300s
CQRS_QUERY_CACHE_MAX_SIZE=10000
CQRS_PROJECTION_BATCH_SIZE=50
CQRS_PROJECTION_PARALLEL=true

# =====================================================
# INTEGRAÇÃO EXTERNA
# =====================================================
# DETRAN API (exemplo)
DETRAN_BASE_URL=http://detran-api:8080/api
DETRAN_TIMEOUT=30s
DETRAN_RETRY_MAX_ATTEMPTS=3
DETRAN_RETRY_BACKOFF_DELAY=2s

# ViaCEP
VIACEP_BASE_URL=https://viacep.com.br/ws
VIACEP_TIMEOUT=10s

# =====================================================
# MONITORAMENTO E OBSERVABILIDADE
# =====================================================
# Actuator
MANAGEMENT_ENDPOINTS_ENABLED=true
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus,eventstore,snapshots,cqrs,replay
MANAGEMENT_HEALTH_SHOW_DETAILS=always

# Métricas
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=0.1

# =====================================================
# LOGGING
# =====================================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_SEGURADORA_HIBRIDA=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=WARN
LOGGING_LEVEL_ORG_AXONFRAMEWORK=INFO
LOGGING_LEVEL_ORG_HIBERNATE=WARN

# Arquivo de Log
LOGGING_FILE_NAME=/app/logs/arquitetura-hibrida.log
LOGGING_FILE_MAX_SIZE=10MB
LOGGING_FILE_MAX_HISTORY=30

# =====================================================
# ASYNC E THREAD POOLS
# =====================================================
ASYNC_CORE_POOL_SIZE=10
ASYNC_MAX_POOL_SIZE=50
ASYNC_QUEUE_CAPACITY=1000

# =====================================================
# SPRINGDOC / SWAGGER
# =====================================================
SPRINGDOC_API_DOCS_ENABLED=true
SPRINGDOC_SWAGGER_UI_ENABLED=true
SPRINGDOC_SWAGGER_UI_PATH=/swagger-ui.html

# =====================================================
# JVM OPTIONS (para Docker)
# =====================================================
JAVA_OPTS=-Xmx1g -Xms512m -XX:+UseG1GC -XX:+UseStringDeduplication -XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0

# =====================================================
# TIMEZONE
# =====================================================
TZ=America/Sao_Paulo

# =====================================================
# FERRAMENTAS DE GESTÃO (DOCKER)
# =====================================================
# PgAdmin
PGADMIN_EMAIL=admin@hibrida.com
PGADMIN_PASSWORD=admin123
