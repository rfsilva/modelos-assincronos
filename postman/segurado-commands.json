							"    pm.expect(jsonData.message).to.include('desativado');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "{{contentType}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"motivo\": \"Solicitação do cliente\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/{{apiVersion}}/segurados/{{seguradoId}}/desativar",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"{{apiVersion}}",
						"segurados",
						"{{seguradoId}}",
						"desativar"
					]
				}
			},
			"response": []
		},
		{
			"name": "Reativar Segurado",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response has success field\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('success');",
							"    pm.expect(jsonData.success).to.be.true;",
							"});",
							"",
							"pm.test(\"Response has message\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('message');",
							"    pm.expect(jsonData.message).to.include('reativado');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "{{contentType}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"motivo\": \"Cliente retornou interesse\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/{{apiVersion}}/segurados/{{seguradoId}}/reativar",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"{{apiVersion}}",
						"segurados",
						"{{seguradoId}}",
						"reativar"
					]
				}
			},
			"response": []
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Script executado antes de cada request",
					"console.log('Executando request para Segurado Commands...');"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Script executado após cada request",
					"console.log('Request finalizado para Segurado Commands');"
				]
			}
		}
	]
}