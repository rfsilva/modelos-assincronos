		{
			"name": "Listar Handlers Registrados",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response has handlers data\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('registeredHandlers');",
							"    pm.expect(jsonData).to.have.property('totalHandlers');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/command-bus/handlers",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"command-bus",
						"handlers"
					]
				}
			},
			"response": []
		},
		{
			"name": "Verificar Handler Específico",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200 or 404\", function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
							"});",
							"",
							"if (pm.response.code === 200) {",
							"    pm.test(\"Response has handler info\", function () {",
							"        var jsonData = pm.response.json();",
							"        pm.expect(jsonData).to.have.property('commandType');",
							"        pm.expect(jsonData).to.have.property('handlerClass');",
							"        pm.expect(jsonData).to.have.property('registered');",
							"    });",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/command-bus/handlers/CriarSeguradoCommand",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"command-bus",
						"handlers",
						"CriarSeguradoCommand"
					]
				}
			},
			"response": []
		},
		{
			"name": "Reset Estatísticas",
