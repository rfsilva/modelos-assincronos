{
	"info": {
		"_postman_id": "command-bus-collection",
		"name": "Command Bus - Monitoring",
		"description": "Collection para testar os endpoints de monitoramento do Command Bus",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health Check - Command Bus",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response has health data\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('status');",
							"    pm.expect(jsonData).to.have.property('commandBus');",
							"    pm.expect(jsonData).to.have.property('registeredHandlers');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/command-bus/health",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"command-bus",
						"health"
					]
				}
			},
			"response": []
		},
		{
			"name": "Obter Estatísticas do Command Bus",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response has statistics data\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('totalCommands');",
							"    pm.expect(jsonData).to.have.property('successfulCommands');",
							"    pm.expect(jsonData).to.have.property('failedCommands');",
							"    pm.expect(jsonData).to.have.property('averageExecutionTime');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
