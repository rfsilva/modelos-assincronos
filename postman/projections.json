					"script": {
						"exec": [
							"pm.test(\"Status code is 200 or 404\", function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
							"});",
							"",
							"if (pm.response.code === 200) {",
							"    pm.test(\"Response has projection data\", function () {",
							"        var jsonData = pm.response.json();",
							"        pm.expect(jsonData).to.have.property('projectionName');",
							"        pm.expect(jsonData).to.have.property('status');",
							"        pm.expect(jsonData).to.have.property('lastProcessedEventId');",
							"        pm.expect(jsonData).to.have.property('eventsProcessed');",
							"    });",
							"}"
