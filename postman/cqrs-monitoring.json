{
	"info": {
		"_postman_id": "cqrs-monitoring-collection",
		"name": "CQRS - Monitoring",
		"description": "Collection para testar os endpoints de monitoramento geral do CQRS",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health Check - CQRS",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response has health data\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('status');",
							"    pm.expect(jsonData).to.have.property('cqrs');",
							"    pm.expect(jsonData).to.have.property('commandSide');",
							"    pm.expect(jsonData).to.have.property('querySide');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/{{apiVersion}}/cqrs/health",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"{{apiVersion}}",
						"cqrs",
						"health"
					]
				}
			},
			"response": []
		},
