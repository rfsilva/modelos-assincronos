{
	"info": {
		"_postman_id": "health-check-collection",
		"name": "Health Check - Sistema",
		"description": "Collection para testar os endpoints de health check e monitoramento geral do sistema",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health Check - Sistema Geral",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response has health data\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('status');",
							"    pm.expect(jsonData).to.have.property('sistema');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/sistema/health",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"sistema",
						"health"
					]
				}
			},
			"response": []
		},
